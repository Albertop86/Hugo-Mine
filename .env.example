# ── Required in production ────────────────────────────────────────────
# Your deployed URL (no trailing slash). Used for sitemap + robots.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# ── Set automatically by Vercel when you connect a Blob store ─────────
# Enables community skin uploads. Leave empty to disable (gallery still works).
BLOB_READ_WRITE_TOKEN=
